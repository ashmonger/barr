# Recyclarr configuration — generated by Ansible, do not edit manually.
# Extend quality_definition and custom_formats per the TRaSH Guides docs:
# https://recyclarr.dev/wiki/yaml/config-reference/

sonarr:
  main:
    base_url: "http://localhost:{{ (servarr_apps | selectattr('name', 'equalto', 'Sonarr') | list | first).port }}"
    api_key: "{{ sonarr_api_key }}"
    quality_definition:
      type: series

radarr:
  main:
    base_url: "http://localhost:{{ (servarr_apps | selectattr('name', 'equalto', 'Radarr') | list | first).port }}"
    api_key: "{{ radarr_api_key }}"
    quality_definition:
      type: movie
