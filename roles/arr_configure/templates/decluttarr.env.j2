# Decluttarr environment — generated by Ansible, do not edit manually.

# Sonarr
SONARR_URL=http://localhost:{{ (servarr_apps | selectattr('name', 'equalto', 'Sonarr') | list | first).port }}
SONARR_KEY={{ sonarr_api_key }}

# Radarr
RADARR_URL=http://localhost:{{ (servarr_apps | selectattr('name', 'equalto', 'Radarr') | list | first).port }}
RADARR_KEY={{ radarr_api_key }}

# Lidarr
LIDARR_URL=http://localhost:{{ (servarr_apps | selectattr('name', 'equalto', 'Lidarr') | list | first).port }}
LIDARR_KEY={{ lidarr_api_key }}

# qBittorrent
QBITTORRENT_URL=http://localhost:{{ qbittorrent_port }}
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=

# Behaviour
REMOVE_TIMER={{ decluttarr_remove_timer }}
REMOVE_FAILED={{ decluttarr_remove_failed | string | capitalize }}
REMOVE_STALLED={{ decluttarr_remove_stalled | string | capitalize }}
REMOVE_METADATA_MISSING={{ decluttarr_remove_metadata_missing | string | capitalize }}
REMOVE_MISSING_FILES={{ decluttarr_remove_missing_files | string | capitalize }}
REMOVE_ORPHANS={{ decluttarr_remove_orphans | string | capitalize }}
IGNORE_PRIVATE_TRACKERS={{ decluttarr_ignore_private_trackers | string | capitalize }}
TEST_RUN={{ decluttarr_test_run | string | capitalize }}
LOG_LEVEL={{ decluttarr_log_level }}
