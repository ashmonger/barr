# Unpackerr configuration — generated by Ansible, do not edit manually.

[unpackerr]
debug      = false
quiet      = false
log_queues = "1m"
interval   = "1m"
start_delay = "1m"
retry_delay = "5m"
retry_max  = 3
parallel   = 1
file_mode  = "0644"
dir_mode   = "0755"

{% for app in servarr_apps | selectattr('name', 'in', ['Sonarr', 'Radarr', 'Lidarr']) %}
[[{{ app.name | lower }}]]
  url       = "http://localhost:{{ app.port }}"
  api_key   = "{{ lookup('vars', app.name | lower + '_api_key') }}"
  paths     = ["{{ arr_downloads_complete }}"]
  protocols = "torrent"
  timeout   = "10s"
  delete_orig  = false
  delete_delay = "5m"

{% endfor %}
